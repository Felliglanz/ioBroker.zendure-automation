{
  "type": "tabs",
  "i18n": true,
  "items": {
    "_tabBasic": {
      "type": "panel",
      "label": {
        "en": "⚙️ Basic Settings",
        "de": "⚙️ Basis-Einstellungen"
      },
      "items": {
        "_header": {
          "type": "header",
          "text": {
            "en": "Zendure Automation - Zero Grid Target",
            "de": "Zendure Automation - Nulleinspeisung"
          },
          "size": 2
        },
        "_info": {
          "type": "staticText",
          "text": {
            "en": "Automatic battery control for zero grid feed-in/draw. Configure the required settings below to get started.",
            "de": "Automatische Batteriesteuerung für Null-Netzbezug/-Einspeisung. Konfiguriere unten die erforderlichen Einstellungen."
          },
          "sm": 12,
          "style": {
            "backgroundColor": "#e3f2fd",
            "padding": "10px",
            "borderRadius": "4px",
            "color": "#1565c0"
          }
        },
        "_panelDevice": {
          "type": "panel",
          "label": {
            "en": "🔌 Device Connection (Required)",
            "de": "🔌 Geräte-Verbindung (Erforderlich)"
          },
          "items": {
            "zendureSolarflowInstance": {
              "type": "text",
              "label": {
                "en": "Zendure Solarflow adapter instance",
                "de": "Zendure Solarflow Adapter-Instanz"
              },
              "placeholder": "zendure-solarflow.0",
              "sm": 12,
              "help": {
                "en": "The instance name of the nograx zendure-solarflow adapter",
                "de": "Der Instanzname des nograx zendure-solarflow Adapters"
              }
            },
            "deviceProductKey": {
              "type": "text",
              "label": {
                "en": "Device ProductKey",
                "de": "Gerät ProductKey"
              },
              "sm": 6,
              "help": {
                "en": "The ProductKey of your Zendure device",
                "de": "Der ProductKey deines Zendure Geräts"
              }
            },
            "deviceKey": {
              "type": "text",
              "label": {
                "en": "Device Key",
                "de": "Gerät DeviceKey"
              },
              "sm": 6,
              "help": {
                "en": "The DeviceKey of your Zendure device",
                "de": "Der DeviceKey deines Zendure Geräts"
              }
            },
            "_deviceHint": {
              "type": "staticText",
              "text": {
                "en": "💡 Find ProductKey and DeviceKey in the zendure-solarflow adapter object tree under your device.",
                "de": "💡 ProductKey und DeviceKey findest du im zendure-solarflow Adapter unter deinem Gerät im Objektbaum."
              },
              "sm": 12,
              "style": {
                "fontSize": "0.85em",
                "fontStyle": "italic",
                "color": "#666",
                "marginTop": "5px"
              }
            }
          }
        },
        "_panelMeter": {
          "type": "panel",
          "label": {
            "en": "📊 Grid Power Meter (Required)",
            "de": "📊 Netz-Stromzähler (Erforderlich)"
          },
          "items": {
            "powerMeterDp": {
              "type": "objectId",
              "label": {
                "en": "Grid power datapoint",
                "de": "Netzleistungs-Datenpunkt"
              },
              "sm": 12,
              "types": ["state"],
              "help": {
                "en": "Datapoint with current grid power (positive = drawing, negative = feeding)",
                "de": "Datenpunkt mit aktueller Netzleistung (positiv = Bezug, negativ = Einspeisung)"
              }
            },
            "_meterHint": {
              "type": "staticText",
              "text": {
                "en": "💡 Convention: Positive values = grid draw (consuming), negative = grid feed-in (producing)",
                "de": "💡 Konvention: Positive Werte = Netzbezug (Verbrauch), negativ = Einspeisung (Erzeugung)"
              },
              "sm": 12,
              "style": {
                "fontSize": "0.85em",
                "fontStyle": "italic",
                "color": "#666",
                "marginTop": "5px"
              }
            }
          }
        }
      }
    },
    "_tabControl": {
      "type": "panel",
      "label": {
        "en": "🎯 Zero Grid Control",
        "de": "🎯 Nulleinspeisung"
      },
      "items": {
        "_panelTarget": {
          "type": "panel",
          "label": {
            "en": "Target & Timing",
            "de": "Ziel & Timing"
          },
          "items": {
            "targetGridPowerW": {
              "type": "number",
              "label": {
                "en": "Target grid power (W)",
                "de": "Ziel-Netzleistung (W)"
              },
              "sm": 6,
              "min": -5000,
              "max": 5000,
              "help": {
                "en": "0 = zero grid, positive = allow grid draw, negative = allow feed-in",
                "de": "0 = Nulleinspeisung, positiv = Netzbezug erlaubt, negativ = Einspeisung erlaubt"
              }
            },
            "updateIntervalSec": {
              "type": "number",
              "label": {
                "en": "Update interval (seconds)",
                "de": "Update-Intervall (Sekunden)"
              },
              "sm": 6,
              "min": 1,
              "max": 300,
              "help": {
                "en": "How often to adjust battery power (recommended: 5s)",
                "de": "Wie oft Batterieleistung angepasst wird (empfohlen: 5s)"
              }
            }
          }
        },
        "_panelRegulation": {
          "type": "panel",
          "label": {
            "en": "Regulation Parameters",
            "de": "Regelparameter"
          },
          "items": {
            "hysteresisW": {
              "type": "number",
              "label": {
                "en": "Hysteresis (W)",
                "de": "Hysterese (W)"
              },
              "sm": 4,
              "min": 0,
              "max": 500,
              "help": {
                "en": "Minimum power change to react (avoids small adjustments)",
                "de": "Minimale Leistungsänderung zum Reagieren (vermeidet kleine Anpassungen)"
              }
            },
            "rampChargeWPerCycle": {
              "type": "number",
              "label": {
                "en": "Charge ramp (W/cycle)",
                "de": "Lade-Rampe (W/Zyklus)"
              },
              "sm": 4,
              "min": 0,
              "max": 2000,
              "help": {
                "en": "Max charge power change per cycle (higher = faster)",
                "de": "Max. Ladeänderung pro Zyklus (höher = schneller)"
              }
            },
            "rampDischargeWPerCycle": {
              "type": "number",
              "label": {
                "en": "Discharge ramp (W/cycle)",
                "de": "Entlade-Rampe (W/Zyklus)"
              },
              "sm": 4,
              "min": 0,
              "max": 2000,
              "help": {
                "en": "Max discharge power change per cycle (higher = faster)",
                "de": "Max. Entladeänderung pro Zyklus (höher = schneller)"
              }
            },
            "_regulationHint": {
              "type": "staticText",
              "text": {
                "en": "⚙️ Higher ramps = faster response (aggressive), lower = smoother (gentle). Hysteresis prevents oscillation around target.",
                "de": "⚙️ Höhere Rampen = schnellere Reaktion (aggressiv), niedriger = sanfter. Hysterese verhindert Oszillation um Zielwert."
              },
              "sm": 12,
              "style": {
                "fontSize": "0.85em",
                "fontStyle": "italic",
                "color": "#666",
                "marginTop": "10px",
                "padding": "8px",
                "backgroundColor": "#f5f5f5",
                "borderRadius": "4px"
              }
            }
          }
        },
        "_panelFeatures": {
          "type": "panel",
          "label": {
            "en": "Enable/Disable",
            "de": "Aktivieren/Deaktivieren"
          },
          "items": {
            "enableCharge": {
              "type": "checkbox",
              "label": {
                "en": "Enable charging",
                "de": "Laden aktivieren"
              },
              "sm": 6,
              "help": {
                "en": "Allow battery charging",
                "de": "Batterie-Laden erlauben"
              }
            },
            "enableDischarge": {
              "type": "checkbox",
              "label": {
                "en": "Enable discharging",
                "de": "Entladen aktivieren"
              },
              "sm": 6,
              "help": {
                "en": "Allow battery discharge",
                "de": "Batterie-Entladung erlauben"
              }
            }
          }
        }
      }
    },
    "_tabRelay": {
      "type": "panel",
      "label": {
        "en": "⚡ Relay Protection",
        "de": "⚡ Relais-Schutz"
      },
      "items": {
        "_relayInfo": {
          "type": "staticText",
          "text": {
            "en": "⚡ Protection against frequent relay switching: Requires sustained grid conditions before mode transitions. Additional 10W-check ensures relay only switches at minimal current (~0.04A).",
            "de": "⚡ Schutz vor häufigem Relais-Schalten: Erfordert nachhaltige Netzbedingungen vor Moduswechsel. Zusätzlicher 10W-Check stellt sicher, dass Relais nur bei minimalem Strom (~0,04A) schaltet."
          },
          "sm": 12,
          "style": {
            "backgroundColor": "#fff3e0",
            "padding": "12px",
            "borderRadius": "4px",
            "color": "#e65100",
            "marginBottom": "15px"
          }
        },
        "_panelChargeSwitch": {
          "type": "panel",
          "label": {
            "en": "Transition to Charging",
            "de": "Umschaltung auf Laden"
          },
          "items": {
            "feedInThresholdW": {
              "type": "number",
              "label": {
                "en": "Feed-in threshold (W)",
                "de": "Einspeise-Schwellwert (W)"
              },
              "sm": 6,
              "min": -5000,
              "max": 0,
              "help": {
                "en": "Start charging when feed-in exceeds this (negative value, e.g. -150W)",
                "de": "Laden starten bei Überschreitung (negativer Wert, z.B. -150W)"
              }
            },
            "feedInDelayTicks": {
              "type": "number",
              "label": {
                "en": "Feed-in delay (ticks)",
                "de": "Einspeise-Verzögerung (Ticks)"
              },
              "sm": 6,
              "min": 0,
              "max": 20,
              "help": {
                "en": "Cycles feed-in must persist before switching (1 tick = interval)",
                "de": "Zyklen die Einspeisung anhalten muss (1 Tick = Intervall)"
              }
            },
            "_chargeHint": {
              "type": "staticText",
              "text": {
                "en": "After delay: Relay only switches when battery power < 10W (safe switching at ~0.04A)",
                "de": "Nach Verzögerung: Relais schaltet nur bei Batterieleistung < 10W (sicheres Schalten bei ~0,04A)"
              },
              "sm": 12,
              "style": {
                "fontSize": "0.85em",
                "color": "#2e7d32",
                "marginTop": "8px",
                "padding": "6px",
                "backgroundColor": "#e8f5e9",
                "borderRadius": "4px"
              }
            }
          }
        },
        "_panelDischargeSwitch": {
          "type": "panel",
          "label": {
            "en": "Transition to Discharging",
            "de": "Umschaltung auf Entladen"
          },
          "items": {
            "dischargeThresholdW": {
              "type": "number",
              "label": {
                "en": "Grid draw threshold (W)",
                "de": "Netzbezugs-Schwellwert (W)"
              },
              "sm": 6,
              "min": 0,
              "max": 5000,
              "help": {
                "en": "Start discharging when grid draw exceeds this (positive value, e.g. 200W)",
                "de": "Entladen starten bei Überschreitung (positiver Wert, z.B. 200W)"
              }
            },
            "dischargeDelayTicks": {
              "type": "number",
              "label": {
                "en": "Discharge delay (ticks)",
                "de": "Entlade-Verzögerung (Ticks)"
              },
              "sm": 6,
              "min": 0,
              "max": 20,
              "help": {
                "en": "Cycles grid draw must persist before switching (1 tick = interval)",
                "de": "Zyklen die Netzbezug anhalten muss (1 Tick = Intervall)"
              }
            },
            "_dischargeHint": {
              "type": "staticText",
              "text": {
                "en": "After delay: Relay only switches when battery power < 10W (safe switching at ~0.04A)",
                "de": "Nach Verzögerung: Relais schaltet nur bei Batterieleistung < 10W (sicheres Schalten bei ~0,04A)"
              },
              "sm": 12,
              "style": {
                "fontSize": "0.85em",
                "color": "#2e7d32",
                "marginTop": "8px",
                "padding": "6px",
                "backgroundColor": "#e8f5e9",
                "borderRadius": "4px"
              }
            }
          }
        }
      }
    },
    "_tabBattery": {
      "type": "panel",
      "label": {
        "en": "🔋 Battery Protection",
        "de": "🔋 Akku-Schutz"
      },
      "items": {
        "_panelPowerLimits": {
          "type": "panel",
          "label": {
            "en": "Power Limits",
            "de": "Leistungsgrenzen"
          },
          "items": {
            "maxChargePowerW": {
              "type": "number",
              "label": {
                "en": "Max. charge power (W)",
                "de": "Max. Ladeleistung (W)"
              },
              "sm": 6,
              "min": 0,
              "max": 3000,
              "help": {
                "en": "Maximum charging power",
                "de": "Maximale Ladeleistung"
              }
            },
            "maxDischargePowerW": {
              "type": "number",
              "label": {
                "en": "Max. discharge power (W)",
                "de": "Max. Entladeleistung (W)"
              },
              "sm": 6,
              "min": 0,
              "max": 3000,
              "help": {
                "en": "Maximum discharging power",
                "de": "Maximale Entladeleistung"
              }
            }
          }
        },
        "_panelProtection": {
          "type": "panel",
          "label": {
            "en": "Discharge Protection Mode",
            "de": "Entladeschutz-Modus"
          },
          "items": {
            "dischargeProtectionMode": {
              "type": "select",
              "label": {
                "en": "Protection mode",
                "de": "Schutzmodus"
              },
              "sm": 12,
              "options": [
                { 
                  "label": {
                    "en": "By SOC percentage (%)",
                    "de": "Nach SOC Prozent (%)"
                  }, 
                  "value": "soc" 
                },
                { 
                  "label": {
                    "en": "By pack cell voltage (V)",
                    "de": "Nach Pack-Zellspannung (V)"
                  }, 
                  "value": "voltage" 
                }
              ],
              "help": {
                "en": "Choose discharge protection method: SOC percentage or pack voltage",
                "de": "Wähle Entladeschutz-Methode: SOC-Prozent oder Pack-Spannung"
              }
            }
          }
        },
        "_panelSocProtection": {
          "type": "panel",
          "label": {
            "en": "SOC Protection (when mode = soc)",
            "de": "SOC-Schutz (wenn Modus = soc)"
          },
          "items": {
            "minBatterySoc": {
              "type": "number",
              "label": {
                "en": "Minimum SOC (%)",
                "de": "Minimaler SOC (%)"
              },
              "sm": 6,
              "min": 0,
              "max": 100,
              "help": {
                "en": "Stop discharge below this SOC",
                "de": "Entladung stoppen unter diesem SOC"
              }
            },
            "maxBatterySoc": {
              "type": "number",
              "label": {
                "en": "Maximum SOC (%)",
                "de": "Maximaler SOC (%)"
              },
              "sm": 6,
              "min": 0,
              "max": 100,
              "help": {
                "en": "Stop charge above this SOC",
                "de": "Laden stoppen über diesem SOC"
              }
            }
          }
        },
        "_panelVoltageProtection": {
          "type": "panel",
          "label": {
            "en": "Voltage Protection (when mode = voltage)",
            "de": "Spannungs-Schutz (wenn Modus = voltage)"
          },
          "items": {
            "minBatteryVoltageV": {
              "type": "number",
              "label": {
                "en": "Minimum pack voltage (V)",
                "de": "Minimale Pack-Spannung (V)"
              },
              "sm": 6,
              "min": 2.5,
              "max": 3.5,
              "step": 0.01,
              "help": {
                "en": "Stop discharge when ANY pack drops below (typical: 3.0V for LFP)",
                "de": "Entladung stoppen wenn IRGENDEIN Pack darunter fällt (typisch: 3.0V für LFP)"
              }
            },
            "voltageRecoveryHysteresisV": {
              "type": "number",
              "label": {
                "en": "Recovery hysteresis (V)",
                "de": "Recovery-Hysterese (V)"
              },
              "sm": 6,
              "min": 0.0,
              "max": 0.5,
              "step": 0.01,
              "help": {
                "en": "Voltage must rise min+hysteresis before discharge allowed again (prevents oscillation)",
                "de": "Spannung muss min+Hysterese überschreiten vor erneuter Entladung (verhindert Oszillation)"
              }
            },
            "_voltageHint": {
              "type": "staticText",
              "text": {
                "en": "Example: min=3.0V, hysteresis=0.1V → discharge blocked until voltage reaches 3.1V",
                "de": "Beispiel: min=3.0V, Hysterese=0.1V → Entladung blockiert bis Spannung 3.1V erreicht"
              },
              "sm": 12,
              "style": {
                "fontSize": "0.85em",
                "fontStyle": "italic",
                "color": "#666",
                "marginTop": "5px"
              }
            }
          }
        }
      }
    },
    "_tabEmergency": {
      "type": "panel",
      "label": {
        "en": "🚨 Emergency & Recovery",
        "de": "🚨 Notladen & Recovery"
      },
      "items": {
        "_emergencyInfo": {
          "type": "staticText",
          "text": {
            "en": "🚨 Emergency charging is triggered by: critical pack voltage, device flags (lowVoltageBlock/fullChargeNeeded). Ignores grid target and charges with full power until recovery SOC is reached.",
            "de": "🚨 Notladen wird aktiviert bei: kritischer Pack-Spannung, Geräte-Flags (lowVoltageBlock/fullChargeNeeded). Ignoriert Grid-Target und lädt mit voller Kraft bis Recovery-SOC erreicht ist."
          },
          "sm": 12,
          "style": {
            "backgroundColor": "#ffebee",
            "padding": "12px",
            "borderRadius": "4px",
            "color": "#c62828",
            "marginBottom": "15px"
          }
        },
        "_panelEmergencyTrigger": {
          "type": "panel",
          "label": {
            "en": "Emergency Triggers",
            "de": "Notlade-Auslöser"
          },
          "items": {
            "useLowVoltageBlock": {
              "type": "checkbox",
              "label": {
                "en": "Respect device low voltage flag",
                "de": "Geräte-Unterspannungs-Flag beachten"
              },
              "sm": 6,
              "help": {
                "en": "When device reports 'lowVoltageBlock=true', stop discharge immediately",
                "de": "Wenn Gerät 'lowVoltageBlock=true' meldet, Entladung sofort stoppen"
              }
            },
            "useFullChargeNeeded": {
              "type": "checkbox",
              "label": {
                "en": "Respect device full charge request",
                "de": "Geräte-Vollladungs-Anfrage beachten"
              },
              "sm": 6,
              "help": {
                "en": "When device reports 'fullChargeNeeded=true', force full charge (calibration)",
                "de": "Wenn Gerät 'fullChargeNeeded=true' meldet, Vollladung erzwingen (Kalibrierung)"
              }
            },
            "emergencyChargeVoltageV": {
              "type": "number",
              "label": {
                "en": "Critical voltage (V)",
                "de": "Kritische Spannung (V)"
              },
              "sm": 6,
              "min": 2.5,
              "max": 3.0,
              "step": 0.1,
              "help": {
                "en": "Emergency charging when ANY pack below this (typical: 2.8V for LFP)",
                "de": "Notladen wenn IRGENDEIN Pack darunter (typisch: 2.8V für LFP)"
              }
            },
            "emergencyChargePowerW": {
              "type": "number",
              "label": {
                "en": "Emergency charge power (W)",
                "de": "Notlade-Leistung (W)"
              },
              "sm": 6,
              "min": 0,
              "max": 3000,
              "help": {
                "en": "Charging power during emergency (ignores grid)",
                "de": "Ladeleistung während Notladen (ignoriert Netz)"
              }
            }
          }
        },
        "_panelRecovery": {
          "type": "panel",
          "label": {
            "en": "Recovery Settings",
            "de": "Recovery-Einstellungen"
          },
          "items": {
            "emergencyExitSoc": {
              "type": "number",
              "label": {
                "en": "Emergency exit SOC (%)",
                "de": "Notlade-Ende SOC (%)"
              },
              "sm": 6,
              "min": 5,
              "max": 50,
              "help": {
                "en": "Exit emergency at this SOC, enter recovery mode",
                "de": "Notladen beenden bei diesem SOC, Recovery-Mode starten"
              }
            },
            "emergencyRecoverySoc": {
              "type": "number",
              "label": {
                "en": "Recovery complete SOC (%)",
                "de": "Recovery-Ende SOC (%)"
              },
              "sm": 6,
              "min": 10,
              "max": 80,
              "help": {
                "en": "In recovery: only charging allowed until this SOC (prevents emergency loops)",
                "de": "Im Recovery: nur Laden erlaubt bis dieser SOC (verhindert Notlade-Schleifen)"
              }
            },
            "_recoveryHint": {
              "type": "staticText",
              "text": {
                "en": "🔄 Recovery phase: After emergency (at exit SOC), battery continues charging with normal grid target but discharge is blocked until recovery SOC reached. Prevents endless emergency cycles.",
                "de": "🔄 Recovery-Phase: Nach Notladen (ab Exit-SOC) lädt Akku weiter mit normalem Grid-Target, aber Entladung ist blockiert bis Recovery-SOC erreicht. Verhindert Endlos-Notlade-Zyklen."
              },
              "sm": 12,
              "style": {
                "fontSize": "0.85em",
                "padding": "8px",
                "backgroundColor": "#e8f5e9",
                "borderRadius": "4px",
                "color": "#2e7d32",
                "marginTop": "10px"
              }
            }
          }
        }
      }
    },
    "_tabSystem": {
      "type": "panel",
      "label": {
        "en": "⚙️ System",
        "de": "⚙️ System"
      },
      "items": {
        "_panelLogging": {
          "type": "panel",
          "label": {
            "en": "Logging",
            "de": "Protokollierung"
          },
          "items": {
            "logLevel": {
              "type": "select",
              "label": {
                "en": "Log level",
                "de": "Log-Level"
              },
              "sm": 12,
              "options": [
                { "label": "Error", "value": "error" },
                { "label": "Warn", "value": "warn" },
                { "label": "Info", "value": "info" },
                { "label": "Debug", "value": "debug" }
              ],
              "help": {
                "en": "Verbosity of adapter logging (debug = very detailed)",
                "de": "Ausführlichkeit der Adapter-Protokollierung (debug = sehr detailliert)"
              }
            }
          }
        }
      }
    }
  }
}
