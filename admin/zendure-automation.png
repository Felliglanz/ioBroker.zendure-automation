<svg xmlns="http://www.w3.org/2000/svg" width="256" height="256" viewBox="0 0 256 256">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0b1220"/>
      <stop offset="1" stop-color="#0a1b2a"/>
    </linearGradient>
    <linearGradient id="accent" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#6ee7ff"/>
      <stop offset="1" stop-color="#60a5fa"/>
    </linearGradient>
  </defs>

  <rect width="256" height="256" rx="40" fill="url(#bg)"/>

  <!-- Battery body -->
  <rect x="58" y="72" width="140" height="112" rx="22" fill="#0f2033" stroke="url(#accent)" stroke-width="8"/>
  <rect x="198" y="106" width="14" height="44" rx="7" fill="#0f2033" stroke="url(#accent)" stroke-width="8"/>

  <!-- Control sliders (neutral) -->
  <g stroke="#9fb6cc" stroke-width="10" stroke-linecap="round">
    <line x1="86" y1="102" x2="170" y2="102"/>
    <line x1="86" y1="128" x2="170" y2="128"/>
    <line x1="86" y1="154" x2="170" y2="154"/>
  </g>

  <g fill="url(#accent)">
    <circle cx="118" cy="102" r="10"/>
    <circle cx="146" cy="128" r="10"/>
    <circle cx="104" cy="154" r="10"/>
  </g>

  <!-- Small status dot -->
  <circle cx="176" cy="176" r="9" fill="#34d399"/>
</svg>
